<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- ✅ fx:controller sur l'element RACINE (ScrollPane) -->
<ScrollPane
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="com.esprit.controllers.FactureStatsController"
        stylesheets="@/facture-stats.css"
        fitToWidth="true"
        style="-fx-background-color:#f8fafc; -fx-border-color:transparent;">

    <VBox spacing="24" style="-fx-padding:24; -fx-background-color:#f8fafc;">

        <!-- ══ SECTION 1 : CA REEL ══════════════════════════════════════════════ -->
        <VBox spacing="12"
              style="-fx-background-color:white; -fx-border-color:#e5e7eb;
                 -fx-border-radius:12; -fx-background-radius:12;
                 -fx-border-width:1; -fx-padding:20;">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="CA reel - Historique des factures"
                       style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#0f172a;"/>
            </HBox>

            <Label text="Donnees reelles issues de la base de donnees"
                   style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>

            <Separator/>

            <LineChart fx:id="lineChartReel"
                       prefWidth="780" prefHeight="300"
                       animated="false"
                       createSymbols="true"
                       horizontalGridLinesVisible="true"
                       verticalGridLinesVisible="false">
                <xAxis><CategoryAxis label="Mois"/></xAxis>
                <yAxis><NumberAxis label="CA (TND)"/></yAxis>
            </LineChart>

            <!-- Legende -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Region prefWidth="28" prefHeight="3"
                        style="-fx-background-color:#2563eb; -fx-background-radius:2;"/>
                <Label text="CA mensuel reel (TND)"
                       style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>
            </HBox>

        </VBox>

        <!-- ══ SECTION 2 : PREDICTION ML ════════════════════════════════════════ -->
        <VBox spacing="12"
              style="-fx-background-color:white; -fx-border-color:#fed7aa;
                 -fx-border-radius:12; -fx-background-radius:12;
                 -fx-border-width:1; -fx-padding:20;">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="CA predit - 6 prochains mois (Machine Learning)"
                       style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#0f172a;"/>
            </HBox>

            <Label text="Predictions generees par le modele ML"
                   style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>

            <Separator/>

            <LineChart fx:id="lineChartPrediction"
                       prefWidth="780" prefHeight="300"
                       animated="false"
                       createSymbols="true"
                       horizontalGridLinesVisible="true"
                       verticalGridLinesVisible="false">
                <xAxis><CategoryAxis label="Mois"/></xAxis>
                <yAxis><NumberAxis label="CA estime (TND)"/></yAxis>
            </LineChart>

            <!-- Label chargement -->
            <Label fx:id="labelChargementGraph"
                   text="Chargement des predictions..."
                   style="-fx-font-size:12px; -fx-text-fill:#f97316; -fx-font-style:italic;"/>

            <!-- Legende -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Region prefWidth="28" prefHeight="3"
                        style="-fx-background-color:#f97316; -fx-background-radius:2;"/>
                <Label text="CA mensuel predit (TND)"
                       style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>
            </HBox>

        </VBox>

        <!-- ══ SECTION 3 : PREDICTION 1 MOIS ════════════════════════════════════ -->
        <VBox spacing="14"
              style="-fx-background-color:white; -fx-border-color:#c4b5fd;
                 -fx-border-radius:12; -fx-background-radius:12;
                 -fx-border-width:1; -fx-padding:20;">

            <Label text="Prediction pour un mois precis"
                   style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#0f172a;"/>

            <Label text="Choisissez n importe quel mois futur"
                   style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>

            <Separator/>

            <!-- Selecteur de mois -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Choisir le mois :"
                       style="-fx-font-size:13px; -fx-text-fill:#6b7280; -fx-min-width:130;"/>
                <DatePicker fx:id="datePickerPrediction"
                            prefWidth="200"
                            promptText="Mois a predire"/>
            </HBox>

            <!-- Bouton + spinner -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button fx:id="btnPredire"
                        text="Predire"
                        onAction="#lancerPrediction"
                        prefWidth="160" prefHeight="38"
                        style="-fx-background-color:#7c3aed; -fx-text-fill:white;
                       -fx-font-weight:bold; -fx-font-size:13px;
                       -fx-background-radius:8; -fx-cursor:hand;"/>
                <ProgressIndicator fx:id="progressPrediction"
                                   prefWidth="28" prefHeight="28"
                                   visible="false"/>
            </HBox>

            <!-- Resultat -->
            <VBox spacing="6"
                  style="-fx-background-color:#faf5ff; -fx-border-color:#e9d5ff;
                   -fx-border-radius:8; -fx-background-radius:8;
                   -fx-border-width:1; -fx-padding:16;">
                <Label text="CA estime :"
                       style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>
                <Label fx:id="labelResultatCA" text="---"
                       style="-fx-font-size:26px; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                <Label fx:id="labelMarge" text=""
                       style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>
                <Label fx:id="labelModele" text=""
                       style="-fx-font-size:11px; -fx-text-fill:#9ca3af; -fx-font-style:italic;"/>
            </VBox>

            <Label text="Assurez-vous que python app.py est lance avant d utiliser les predictions."
                   wrapText="true"
                   style="-fx-font-size:11px; -fx-text-fill:#9ca3af; -fx-font-style:italic;"/>

        </VBox>

    </VBox>
</ScrollPane>
