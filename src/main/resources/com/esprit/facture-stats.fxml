<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esprit.controllers.FactureStatsController"
      stylesheets="@/facture-stats.css"
      spacing="20"
      style="-fx-padding:20; -fx-background-color:#f8fafc;">

    <!-- TITRE -->
    <Label text="📊 Statistiques Factures - Évolution du Chiffre d'Affaires"
           style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#0f172a;"/>

    <!-- LINE CHART -->
    <LineChart fx:id="lineChart"
               prefWidth="800"
               prefHeight="450"
               animated="false"
               createSymbols="false"
               alternativeRowFillVisible="false"
               alternativeColumnFillVisible="false"
               horizontalGridLinesVisible="true"
               verticalGridLinesVisible="true">

        <!-- AXE X -->
        <xAxis>
            <CategoryAxis label="Mois"/>
        </xAxis>

        <!-- AXE Y -->
        <yAxis>
            <NumberAxis label="Chiffre d'affaires (TND)"/>
        </yAxis>

    </LineChart>

</VBox>