<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.esprit.controllers.FactureTableController"
      spacing="10"
      maxWidth="Infinity"
      maxHeight="Infinity"
      VBox.vgrow="ALWAYS">
    <!-- TITLE -->
    <Label text="Liste des Factures"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 15 0 10 20;"/>

    <!-- SEARCH + TRI -->
    <HBox spacing="10" style="-fx-padding: 10 20 10 20;">

        <TextField fx:id="searchField"
                   promptText="🔍 Rechercher..."
                   onKeyReleased="#filterFactures"
                   HBox.hgrow="ALWAYS"/>

        <ComboBox fx:id="triCombo"
                  promptText="Trier par..."
                  onAction="#trierFactures"
                  prefWidth="220"/>

        <Button text="Reset" onAction="#resetAll"/>
    </HBox>

    <!-- TABLE -->
    <TableView fx:id="factureTable"
               prefHeight="550"
               VBox.vgrow="ALWAYS">

        <columns>
            <TableColumn fx:id="numeroColumn" text="Numéro" prefWidth="120"/>
            <TableColumn fx:id="montantHTColumn" text="HT" prefWidth="100"/>
            <TableColumn fx:id="montantTTCColumn" text="TTC" prefWidth="100"/>
            <TableColumn fx:id="tvaColumn" text="TVA" prefWidth="80"/>
            <TableColumn fx:id="statutColumn" text="Statut" prefWidth="120"/>
            <TableColumn fx:id="livraisonColumn" text="Livraison" prefWidth="120"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="250"/>
        </columns>

    </TableView>

    <!-- MESSAGE -->
    <Label fx:id="messageLabel"
           style="-fx-padding: 8 0 0 20; -fx-text-fill: green;"/>

</VBox>