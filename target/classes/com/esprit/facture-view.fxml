<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.esprit.controllers.FactureController"
      stylesheets="@/facture.css"
      spacing="15"
      style="-fx-padding: 20;">

    <!-- ================= TITLE ================= -->
    <Label text="Gestion des Factures"
           style="-fx-font-size: 22px; -fx-font-weight: bold;" />

    <!-- ================= FORM ================= -->
    <VBox spacing="12" styleClass="card">

        <!-- NUMERO -->
        <HBox spacing="10">
            <TextField fx:id="numeroField"
                       promptText="FAC-2026-001"
                       prefWidth="250"/>

            <Button text="Générer"
                    onAction="#genererNumeroFacture"/>
        </HBox>

        <!-- MONTANTS -->
        <TextField fx:id="montantHTField"
                   promptText="Montant HT"/>

        <TextField fx:id="tvaField"
                   promptText="TVA %"/>

        <TextField fx:id="montantTTCField"
                   promptText="TTC calculé"
                   editable="false"
                   mouseTransparent="true"
                   style="-fx-background-color: #e5e7eb;"/>

        <!-- COMBOS -->
        <ComboBox fx:id="statutCombo"
                  promptText="Statut"/>

        <ComboBox fx:id="cbLivraison"
                  promptText="Livraison ID"/>

        <!-- ACTION BUTTONS -->
        <HBox spacing="10">

            <Button text="Ajouter Facture"
                    onAction="#ajouterFacture"
                    styleClass="btn-primary"/>



        </HBox>



    </VBox>

</VBox>