<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.esprit.controllers.RecompenseTableController"
      spacing="10"
      maxWidth="Infinity"
      maxHeight="Infinity"
      VBox.vgrow="ALWAYS">

    <!-- TITLE -->
    <Label text="Liste des Recompenses"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 15 0 10 20;"/>

    <!-- SEARCH + TRI -->
    <HBox spacing="10" style="-fx-padding: 10 20 10 20;">

        <TextField fx:id="searchField"
                   promptText="Search type, description..."
                   onKeyReleased="#rechercher"
                   HBox.hgrow="ALWAYS"/>

        <ComboBox fx:id="triCombo"
                  promptText="Trier par..."
                  onAction="#trier"
                  prefWidth="220"/>

        <Button text="Top 5"
                onAction="#topRecompenses"/>

        <Button text="Reset"
                onAction="#actualiserTableau"/>

    </HBox>

    <!-- TABLE -->
    <TableView fx:id="recompenseTable"
               VBox.vgrow="ALWAYS"
               prefHeight="550">

        <columns>

            <TableColumn fx:id="typeColumn"
                         text="Type"
                         prefWidth="120"/>

            <TableColumn fx:id="valeurColumn"
                         text="Valeur"
                         prefWidth="100"/>

            <TableColumn fx:id="descriptionColumn"
                         text="Description"
                         prefWidth="180"/>

            <TableColumn fx:id="seuilColumn"
                         text="Seuil"
                         prefWidth="80"/>

            <TableColumn fx:id="dateColumn"
                         text="Date"
                         prefWidth="120"/>

            <TableColumn fx:id="livreurColumn"
                         text="Livreur"
                         prefWidth="130"/>

            <TableColumn fx:id="factureColumn"
                         text="Facture"
                         prefWidth="120"/>

            <TableColumn fx:id="actionsColumn"
                         text="Actions"
                         prefWidth="180"/>

        </columns>

    </TableView>

    <!-- MESSAGE -->
    <Label fx:id="messageLabel"
           text=""
           style="-fx-text-fill: green; -fx-padding: 5 0 0 15;"/>

</VBox>