<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.esprit.controllers.RecompenseTableController"
      stylesheets="@/recompense-table.css">

    <Label text="Liste des Récompenses"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 15;"/>

    <TableView fx:id="recompenseTable"
               prefHeight="450"
               VBox.vgrow="ALWAYS">

        <columns>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="110"/>
            <TableColumn fx:id="valeurColumn" text="Valeur" prefWidth="90"/>
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="200"/>
            <TableColumn fx:id="seuilColumn" text="Seuil" prefWidth="90"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="150"/>
            <TableColumn fx:id="livreurColumn" text="Livreur" prefWidth="130"/>
            <TableColumn fx:id="factureColumn" text="Facture" prefWidth="130"/>
        </columns>

    </TableView>

    <!-- BUTTONS -->
    <HBox spacing="10" style="-fx-padding: 10;">
        <Button text="Modifier"
                onAction="#modifierRecompense"
                style="-fx-background-color: #2563eb; -fx-text-fill: white;"/>

        <Button text="Supprimer"
                onAction="#supprimerRecompense"
                style="-fx-background-color: #dc2626; -fx-text-fill: white;"/>

        <Button text="Actualiser"
                onAction="#actualiserTableau"
                style="-fx-background-color: #374151; -fx-text-fill: white;"/>
    </HBox>

    <!-- MESSAGE -->
    <Label fx:id="messageLabel"
           style="-fx-padding: 10; -fx-text-fill: green;"/>

</VBox>