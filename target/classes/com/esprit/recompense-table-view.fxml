<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.esprit.controllers.FactureTableController"
      spacing="10"
      prefWidth="1050"
      prefHeight="600"
      stylesheets="@/facture-table.css">

    <!-- TITLE -->
    <Label text="Gestion des Factures"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 15 0 10 20;"/>

    <!-- SEARCH + TRI -->
    <HBox spacing="10" style="-fx-padding: 10 20 10 20;">

        <!-- SEARCH -->
        <TextField fx:id="searchField"
                   promptText="🔍 Rechercher (numéro, statut, montant...)"
                   onKeyReleased="#filterFactures"
                   HBox.hgrow="ALWAYS"/>

        <!-- TRI -->
        <ComboBox fx:id="triCombo"
                  promptText="Trier par..."
                  onAction="#trierFactures"
                  prefWidth="220"/>

        <!-- RESET -->
        <Button text="Reset"
                onAction="#resetAll"/>
    </HBox>

    <!-- TABLE -->
    <TableView fx:id="factureTable"
               VBox.vgrow="ALWAYS"
               prefHeight="550">

        <columns>

            <TableColumn fx:id="numeroColumn"
                         text="Numéro"
                         prefWidth="120"/>

            <TableColumn fx:id="montantHTColumn"
                         text="HT"
                         prefWidth="100"/>

            <TableColumn fx:id="montantTTCColumn"
                         text="TTC"
                         prefWidth="100"/>

            <TableColumn fx:id="tvaColumn"
                         text="TVA (%)"
                         prefWidth="80"/>

            <TableColumn fx:id="statutColumn"
                         text="Statut"
                         prefWidth="130"/>

            <TableColumn fx:id="livraisonColumn"
                         text="Livraison"
                         prefWidth="120"/>

            <TableColumn fx:id="actionsColumn"
                         text="Actions"
                         prefWidth="180"/>

        </columns>

    </TableView>

    <!-- MESSAGE -->
    <Label fx:id="messageLabel"
           text=""
           style="-fx-text-fill: green; -fx-padding: 5 0 0 15;"/>

</VBox>